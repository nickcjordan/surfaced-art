{
  "name": "surfaced-art",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "check": "turbo run build typecheck lint test test:integration --force",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "security:scan": "node scripts/security-scan.cjs",
    "security:npm": "node scripts/security-scan.cjs --npm",
    "security:trivy": "node scripts/security-scan.cjs --trivy",
    "security:semgrep": "node scripts/security-scan.cjs --semgrep",
    "security:dependabot": "node scripts/security-scan.cjs --dependabot",
    "security:pr-reviews": "node scripts/security-scan.cjs --pr-reviews",
    "seed:images": "tsx scripts/notion-to-s3.ts",
    "recruit:reddit": "tsx tools/recruit/src/reddit/cli.ts",
    "recruit:fair": "tsx tools/recruit/src/art-fair/cli.ts",
    "recruit:enrich": "tsx tools/recruit/src/enricher/cli.ts",
    "recruit:etsy": "tsx tools/recruit/src/etsy/cli.ts"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@notionhq/client": "^5.11.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "turbo": "^2.8.14",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "lodash": ">=4.17.23"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
