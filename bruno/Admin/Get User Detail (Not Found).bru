meta {
  name: Get User Detail (Not Found)
  type: http
  seq: 11
}

get {
  url: {{sa_baseUrl}}/admin/users/00000000-0000-0000-0000-000000000000
  body: none
  auth: bearer
}

auth:bearer {
  token: {{sa_authToken}}
}

assert {
  res.status: eq 404
  res.body.error.code: eq NOT_FOUND
}

tests {
  test("should return 404 for non-existent user", function() {
    const body = res.getBody();
    expect(body.error.code).to.equal("NOT_FOUND");
  });
}
