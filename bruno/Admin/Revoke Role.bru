meta {
  name: Revoke Role
  type: http
  seq: 14
}

delete {
  url: {{sa_baseUrl}}/admin/users/{{sa_targetUserId}}/roles/artist
  body: none
  auth: bearer
}

auth:bearer {
  token: {{sa_authToken}}
}

assert {
  res.status: eq 200
  res.body.message: isDefined
}

tests {
  test("should revoke role successfully", function() {
    const body = res.getBody();
    expect(body).to.have.property("message");
  });
}
