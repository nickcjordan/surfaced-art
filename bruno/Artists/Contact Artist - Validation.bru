meta {
  name: Contact Artist - Validation
  type: http
  seq: 9
}

post {
  url: {{sa_baseUrl}}/artists/{{sa_artistSlug}}/contact
  body: json
  auth: none
}

body:json {
  {
    "firstName": "",
    "lastName": "",
    "email": "not-an-email",
    "subject": "",
    "message": "short"
  }
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 for invalid input", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should include validation error details", function() {
    const body = res.getBody();
    expect(body).to.have.property("error");
  });
}
