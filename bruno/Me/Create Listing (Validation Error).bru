meta {
  name: Create Listing (Validation Error)
  type: http
  seq: 22
}

post {
  url: {{sa_baseUrl}}/me/listings
  body: json
  auth: bearer
}

auth:bearer {
  token: {{sa_authToken}}
}

body:json {
  {
    "title": "",
    "description": "Missing required fields test",
    "price": -100
  }
}

assert {
  res.status: eq 400
  res.body.error.code: eq VALIDATION_ERROR
}

tests {
  test("should return 400 for invalid listing data", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(400);
    expect(body.error.code).to.equal("VALIDATION_ERROR");
    expect(body.error.details).to.be.an("array");
  });
}
