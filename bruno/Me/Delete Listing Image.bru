meta {
  name: Delete Listing Image
  type: http
  seq: 26
}

delete {
  url: {{sa_baseUrl}}/me/listings/{{sa_myListingId}}/images/{{sa_myListingImageId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{sa_authToken}}
}

assert {
  res.status: eq 204
}

tests {
  test("should return 204 on successful delete", function() {
    expect(res.getStatus()).to.equal(204);
  });
}
