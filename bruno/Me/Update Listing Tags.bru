meta {
  name: Update Listing Tags
  type: http
  seq: 32
}

put {
  url: {{sa_baseUrl}}/me/listings/{{sa_listingId}}/tags
  body: json
  auth: bearer
}

auth:bearer {
  token: {{sa_authToken}}
}

body:json {
  {
    "tagIds": []
  }
}

assert {
  res.status: eq 200
  res.body.tags: isDefined
}

tests {
  test("should return 200 with updated listing tags", function() {
    const body = res.getBody();
    expect(body.tags).to.be.an("array");
  });
}
