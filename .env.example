# Local development environment variables
# Copy to .env and fill in values. Never commit .env.
#
# All NEXT_PUBLIC_* vars are required — the build will throw if any are absent.
# For staging/prod values, see config/dev.env-reference and config/prod.env-reference.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://surfaced:surfaced_local@localhost:5432/surfaced

# ── Site URL (required — no fallback) ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── API URL (required — no fallback) ─────────────────────────────────────────
# Points to the Hono API. In staging/prod, use the API Gateway URL from Terraform output.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Frontend URL (required by API for CORS) ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Auth (Cognito) ────────────────────────────────────────────────────────────
# Get values from Terraform outputs after running terraform apply.
# See config/dev.env-reference for dev values after first deploy.
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=your-cognito-client-id
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-client-id

# ── Revalidation ──────────────────────────────────────────────────────────────
# Protects POST /api/revalidate. Generate with: openssl rand -hex 32
REVALIDATION_SECRET=generate-a-random-secret-here

# ── CDN (CloudFront) ────────────────────────────────────────────────────────
# Dev CloudFront distribution for seed/uploaded images.
# See config/dev.env-reference for the dev URL.
NEXT_PUBLIC_CDN_DOMAINS=https://your-cloudfront-distribution.cloudfront.net

# ── Analytics (PostHog) ───────────────────────────────────────────────────────
# Optional for local dev. Get key from posthog.com project settings.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys for local dev (sk_test_...). Never use live keys locally.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
