DATABASE_URL=postgresql://surfaced:surfaced_local@localhost:5432/surfaced
REVALIDATION_SECRET=generate-a-random-secret-here

# AWS Cognito — required for authentication (get values from Terraform outputs)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=your-cognito-client-id
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-client-id

# PostHog Analytics (https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe Connect — required for artist payout onboarding
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
