# Dev environment variable reference
# Non-secret reference — safe to commit. Real secrets live in GitHub Environment "dev".
# After the first Terraform apply, fill in the <terraform output: ...> placeholders
# and commit the updated values so the team knows which outputs map to which vars.
#
# See config/README.md for full documentation.

# ── Web (Vercel: surfaced-art-dev project) ────────────────────────────────────

NEXT_PUBLIC_SITE_URL=https://dev.surfaced.art
NEXT_PUBLIC_API_URL=<terraform output: api_gateway_url>
NEXT_PUBLIC_COGNITO_USER_POOL_ID=<terraform output: cognito_user_pool_id>
NEXT_PUBLIC_COGNITO_CLIENT_ID=<terraform output: cognito_client_id>
REVALIDATION_SECRET=<generate: openssl rand -hex 32>

# CloudFront CDN for uploaded images (dev bucket)
NEXT_PUBLIC_CDN_DOMAINS=https://d2agn4aoo0e7ji.cloudfront.net

# Analytics (optional for dev — can share prod project or leave unset)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_dev_project_api_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── API (Lambda env vars — managed by Terraform, not Vercel) ─────────────────
# These are set automatically by Terraform via modules/lambda-api/main.tf.
# Listed here for reference only.

# FRONTEND_URL=https://dev.surfaced.art
# DATABASE_URL=<rds connection string from terraform output>
# COGNITO_USER_POOL_ID=<terraform output: cognito_user_pool_id>
# COGNITO_CLIENT_ID=<terraform output: cognito_client_id>
# S3_BUCKET_NAME=surfaced-art-dev-media
# CLOUDFRONT_URL=https://d2agn4aoo0e7ji.cloudfront.net
# SES_FROM_ADDRESS=support@surfaced.art
# STRIPE_SECRET_KEY=<GitHub secret: TF_VAR_stripe_secret_key>
# STRIPE_WEBHOOK_SECRET=<GitHub secret: TF_VAR_stripe_webhook_secret>
